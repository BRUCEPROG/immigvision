# ── ImmigVision — Variables d'environnement ──
# Copiez ce fichier en .env et remplissez les valeurs

# Clé secrète Flask (changez absolument en production !)
SECRET_KEY=changez-cette-cle-secrete-en-production-2026-abc123xyz

# Chemin de la base de données SQLite
DATABASE_PATH=immigvision.db

# Debug (false en production)
FLASK_DEBUG=false

# Port (défini automatiquement par l'hébergeur)
# PORT=5000
